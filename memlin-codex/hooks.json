{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.codex/plugins/cache/memlin/memlin/0.2.16/dist/hooks/session-start.js\"",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.codex/plugins/cache/memlin/memlin/0.2.16/dist/hooks/user-prompt-submit.js\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.codex/plugins/cache/memlin/memlin/0.2.16/dist/hooks/pre-tool-use.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.codex/plugins/cache/memlin/memlin/0.2.16/dist/hooks/post-tool-use.js\"",
            "timeout": 10
          }
        ],
        "matcher": "Edit|Write|MultiEdit|Bash"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.codex/plugins/cache/memlin/memlin/0.2.16/dist/hooks/stop.js\"",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
